/ingredients/categories/*/        /ingredients/categories/_spa/        200
/ingredients/categories/:id       /ingredients/categories/_spa/        200
/pantry/decoration/categories/*/  /pantry/decoration/categories/_spa/  200
/pantry/decoration/categories/:id /pantry/decoration/categories/_spa/  200
/pantry/decoration/designs/*/     /pantry/decoration/designs/_spa/     200
/pantry/decoration/designs/:id    /pantry/decoration/designs/_spa/     200
/products/categories/*/           /products/categories/_spa/           200
/products/categories/:id          /products/categories/_spa/           200

