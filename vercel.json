{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/app", "destination": "/today", "permanent": false },
    { "source": "/lab/:path*", "destination": "/", "permanent": false },
    { "source": "/lab", "destination": "/", "permanent": false },
    { "source": "/calculator/:path*", "destination": "/", "permanent": false },
    { "source": "/calculator", "destination": "/", "permanent": false }
  ],
  "rewrites": [
    { "source": "/production/:id/products/:path*", "destination": "/production/_spa/products/:path*" },
    { "source": "/production/:id/products", "destination": "/production/_spa/products/" },
    { "source": "/production/:id/products/", "destination": "/production/_spa/products/" },
    { "source": "/production/:id/summary/:path*", "destination": "/production/_spa/summary/:path*" },
    { "source": "/production/:id/summary", "destination": "/production/_spa/summary/" },
    { "source": "/production/:id/summary/", "destination": "/production/_spa/summary/" },
    { "source": "/production/:id/:path*", "destination": "/production/_spa/:path*" },
    { "source": "/production/:id", "destination": "/production/_spa/" },
    { "source": "/production/:id/", "destination": "/production/_spa/" },
    { "source": "/calculator/:id/batch/:path*", "destination": "/calculator/_spa/batch/:path*" },
    { "source": "/calculator/:id/batch", "destination": "/calculator/_spa/batch/" },
    { "source": "/calculator/:id/batch/", "destination": "/calculator/_spa/batch/" },
    { "source": "/calculator/:id/run/:path*", "destination": "/calculator/_spa/run/:path*" },
    { "source": "/calculator/:id/run", "destination": "/calculator/_spa/run/" },
    { "source": "/calculator/:id/run/", "destination": "/calculator/_spa/run/" },
    { "source": "/fillings/categories/:id/:path*", "destination": "/fillings/categories/_spa/:path*" },
    { "source": "/fillings/categories/:id", "destination": "/fillings/categories/_spa/" },
    { "source": "/fillings/categories/:id/", "destination": "/fillings/categories/_spa/" },
    { "source": "/ingredients/categories/:id/:path*", "destination": "/ingredients/categories/_spa/:path*" },
    { "source": "/ingredients/categories/:id", "destination": "/ingredients/categories/_spa/" },
    { "source": "/ingredients/categories/:id/", "destination": "/ingredients/categories/_spa/" },
    { "source": "/pantry/decoration/categories/:id/:path*", "destination": "/pantry/decoration/categories/_spa/:path*" },
    { "source": "/pantry/decoration/categories/:id", "destination": "/pantry/decoration/categories/_spa/" },
    { "source": "/pantry/decoration/categories/:id/", "destination": "/pantry/decoration/categories/_spa/" },
    { "source": "/pantry/decoration/designs/:id/:path*", "destination": "/pantry/decoration/designs/_spa/:path*" },
    { "source": "/pantry/decoration/designs/:id", "destination": "/pantry/decoration/designs/_spa/" },
    { "source": "/pantry/decoration/designs/:id/", "destination": "/pantry/decoration/designs/_spa/" },
    { "source": "/products/categories/:id/:path*", "destination": "/products/categories/_spa/:path*" },
    { "source": "/products/categories/:id", "destination": "/products/categories/_spa/" },
    { "source": "/products/categories/:id/", "destination": "/products/categories/_spa/" },
    { "source": "/collections/:id/:path*", "destination": "/collections/_spa/:path*" },
    { "source": "/collections/:id", "destination": "/collections/_spa/" },
    { "source": "/collections/:id/", "destination": "/collections/_spa/" },
    { "source": "/fillings/:id/:path*", "destination": "/fillings/_spa/:path*" },
    { "source": "/fillings/:id", "destination": "/fillings/_spa/" },
    { "source": "/fillings/:id/", "destination": "/fillings/_spa/" },
    { "source": "/ingredients/:id/:path*", "destination": "/ingredients/_spa/:path*" },
    { "source": "/ingredients/:id", "destination": "/ingredients/_spa/" },
    { "source": "/ingredients/:id/", "destination": "/ingredients/_spa/" },
    { "source": "/moulds/:id/:path*", "destination": "/moulds/_spa/:path*" },
    { "source": "/moulds/:id", "destination": "/moulds/_spa/" },
    { "source": "/moulds/:id/", "destination": "/moulds/_spa/" },
    { "source": "/packaging/:id/:path*", "destination": "/packaging/_spa/:path*" },
    { "source": "/packaging/:id", "destination": "/packaging/_spa/" },
    { "source": "/packaging/:id/", "destination": "/packaging/_spa/" },
    { "source": "/pantry/decoration/:id/:path*", "destination": "/pantry/decoration/_spa/:path*" },
    { "source": "/pantry/decoration/:id", "destination": "/pantry/decoration/_spa/" },
    { "source": "/pantry/decoration/:id/", "destination": "/pantry/decoration/_spa/" },
    { "source": "/products/:id/:path*", "destination": "/products/_spa/:path*" },
    { "source": "/products/:id", "destination": "/products/_spa/" },
    { "source": "/products/:id/", "destination": "/products/_spa/" },
    { "source": "/shop/new/:id/:path*", "destination": "/shop/new/_spa/:path*" },
    { "source": "/shop/new/:id", "destination": "/shop/new/_spa/" },
    { "source": "/shop/new/:id/", "destination": "/shop/new/_spa/" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.basemaps.cartocdn.com; connect-src 'self' https://*.dexie.cloud wss://*.dexie.cloud https://cloudflareinsights.com; frame-src https://challenges.cloudflare.com; worker-src 'self'; frame-ancestors 'none'; form-action 'self'"
        },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
      ]
    }
  ]
}
